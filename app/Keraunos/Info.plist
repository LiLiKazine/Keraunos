<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The keraunos:// scheme the Share Extension / Shortcuts open the app with. The
	     app's .onOpenURL → IncomingURL path turns keraunos://download?url=… into a
	     download. CFBundleURLName is just a unique id for this URL type. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>io.github.lilikazine.Keraunos</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>keraunos</string>
			</array>
		</dict>
	</array>
	<!-- Expose the app's Documents folder in the Files app (On My iPhone). -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<!-- Some media CDNs serve over plain HTTP (e.g. RedNote/xhscdn returns an
	     http:// .mp4). A downloader must fetch arbitrary, unpredictable media hosts,
	     which can't be enumerated as per-domain exceptions — so allow cleartext loads.
	     This only affects which media URLs URLSession will fetch, not app endpoints. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
